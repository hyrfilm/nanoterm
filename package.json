{
  "name": "nanoterm",
  "version": "0.3.2",
  "description": "pluggable unix emulator for the browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyrfilm/nanoterm"
  },
  "type": "module",
  "main": "./dist-lib/nanoterm.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/nanoterm.js",
      "types": "./dist-lib/index.d.ts"
    },
    "./scripts/build-overlay": "./scripts/build-overlay.mjs"
  },
  "files": [
    "dist-lib",
    "scripts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib && tsc --project tsconfig.lib.json",
    "demo:dev": "vite --config vite.demo.config.ts",
    "demo:build": "vite build --config vite.demo.config.ts",
    "demo:preview": "vite preview --config vite.demo.config.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "overlay:build": "node scripts/build-overlay.mjs --fromDir ./overlay --out ./src/generated/fs-overlay.json",
    "nash:build": "cd nash && dune build",
    "nash:test": "cd nash && dune runtest",
    "prepack": "npm run build:lib"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "tinyglobby": "^0.2.15",
    "typescript": "~5.9.3",
    "vite": "7.3.1",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0"
  },
  "engines": {
    "node": "24.9.0"
  }
}
